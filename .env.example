# NEIS Open API key (keep secret)
NEIS_API_KEY=PUT_YOUR_NEIS_KEY_HERE

# Education office / school codes
NEIS_OFFICE_CODE=YOUR_OFFICE_CODE
NEIS_SCHOOL_CODE=YOUR_SCHOOL_CODE

# School level: els | mis | his
NEIS_SCHOOL_LEVEL=mis

# Class info for timetable
NEIS_GRADE=1
NEIS_CLASS=1

# Optional
NEIS_BASE_URL=https://open.neis.go.kr/hub
PORT=4173
DEFAULT_SCHOOL_NAME=기본 학교

# Production security options
ENABLE_HSTS=false
ENABLE_HTTPS_REDIRECT=false
TRUST_PROXY=false

# Rate limit options
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
# 예시: REDIS_URL=redis://localhost:6379
REDIS_URL=

# Security log file directory
LOG_DIR=logs

# Teacher account server storage
TEACHER_DATA_FILE=data/teachers.json
# 복구코드(잠금 해제/비밀번호 초기화용)
TEACHER_RECOVERY_CODE=CHANGE_ME

# Optional: 학교 선택 목록(JSON 배열, 한 줄)
# 예시:
# SCHOOL_OPTIONS_JSON=[{"id":"wangsun","name":"대구왕선초등학교","officeCode":"D10","schoolCode":"7240055","level":"els","grade":"6","classNo":"1"}]
SCHOOL_OPTIONS_JSON=
